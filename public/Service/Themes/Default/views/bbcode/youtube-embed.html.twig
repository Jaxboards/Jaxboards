<div class="bbcode media youtube">
    <div class="embed">
        <iframe allow="accelerometer;
            autoplay;
            clipboard-write;
            encrypted-media;
            gyroscope;
            picture-in-picture;
            web-share"
            allowfullscreen="allowfullscreen"
            frameborder="0"
            referrerpolicy="strict-origin-when-cross-origin"
            src="{{ embedURL }}" title="YouTube video player"
            ></iframe>
    </div>
</div>
