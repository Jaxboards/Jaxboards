<div class="box login">
    <div class="title">
        Login
    </div>
    <div class="content">
        <form action="{{ url('login') }}" method="post">
            <label for="user">
                Username:
            </label>
            <input type="text" name="user" autocomplete="username">
            <br>
            <label for="pass">
                Password:
            </label>
            <input type="password" name="pass" autocomplete="current-password">
            <br>
            <input type="submit" value="Submit">
        </form>
    </div>
</div>
